# ─────────────────────────────────────────────────────────────────────
#  Required — Admin panel & user auth
# ─────────────────────────────────────────────────────────────────────

# Password for the admin panel login (/admin/login).
# Default is "admin" — CHANGE THIS BEFORE DEPLOYING.
ADMIN_PASSWORD=admin

# Secret used to sign user-session cookies (HMAC-SHA256).
# Generate one with: openssl rand -hex 32
# If unset, falls back to ADMIN_PASSWORD.
AUTH_SECRET=

# ─────────────────────────────────────────────────────────────────────
#  Vercel storage (auto-injected — DO NOT set manually)
# ─────────────────────────────────────────────────────────────────────
#
# When these are present, /admin uploads go to Vercel Blob and user
# accounts + admin metadata persist in Vercel KV. When unset, the app
# falls back to local disk (public/) and a JSON file (data/db.json).
#
# To enable on Vercel:
#   1. Project Settings → Storage → Create database → "Blob"
#   2. Project Settings → Storage → Create database → "KV"
#   3. Vercel auto-injects BLOB_READ_WRITE_TOKEN, KV_REST_API_URL,
#      KV_REST_API_TOKEN, KV_REST_API_READ_ONLY_TOKEN into the project's
#      environment. Re-deploy to pick them up.

# BLOB_READ_WRITE_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# ─────────────────────────────────────────────────────────────────────
#  OAuth providers (optional — leave unset to hide social buttons)
# ─────────────────────────────────────────────────────────────────────
#
# Each provider needs both the CLIENT_ID and CLIENT_SECRET to activate.
# Get credentials from:
#   Google:   https://console.cloud.google.com/apis/credentials
#   Facebook: https://developers.facebook.com/apps/
#   Apple:    https://developer.apple.com/account/resources/identifiers/list/serviceId
#
# Authorized redirect URIs (set in each provider's console):
#   https://your-domain.com/api/auth/callback/{google|facebook|apple}

# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_FACEBOOK_ID=
# AUTH_FACEBOOK_SECRET=
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=

# Required for NextAuth session signing in production.
# Generate with: openssl rand -hex 32
# AUTH_SECRET shared above also covers NextAuth.

# ─────────────────────────────────────────────────────────────────────
#  Other
# ─────────────────────────────────────────────────────────────────────

# Public site URL — used for redirects after logout. Defaults to localhost.
NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app
