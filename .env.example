# ─────────────────────────────────────────────────────────────────────
#  Required for /admin
# ─────────────────────────────────────────────────────────────────────

# Password for the admin panel login (/admin/login).
# Default is "admin" — CHANGE THIS BEFORE DEPLOYING.
ADMIN_PASSWORD=admin

# ─────────────────────────────────────────────────────────────────────
#  Required for /account/* (user accounts)
# ─────────────────────────────────────────────────────────────────────

# Secret used to sign user-session cookies (HMAC-SHA256).
# Generate one with: openssl rand -hex 32
# If unset, falls back to ADMIN_PASSWORD.
AUTH_SECRET=

# ─────────────────────────────────────────────────────────────────────
#  Optional
# ─────────────────────────────────────────────────────────────────────

# Public site URL — used for redirects after logout. Defaults to localhost.
NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app
